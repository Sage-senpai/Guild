# ── Demo identity ────────────────────────────────────────────────
DEMO_WALLET_ADDRESS=0xDEMO_WALLET_ADDRESS
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_TOPUP_TREASURY_ADDRESS=
# Optional server-side override (if unset, NEXT_PUBLIC_TOPUP_TREASURY_ADDRESS is used).
TOPUP_TREASURY_ADDRESS=

# ── AI Compute ───────────────────────────────────────────────────
# "real" → 0G Compute broker; falls back to OpenRouter if OPENROUTER_API_KEY is set;
# falls back to mock if neither is configured.
ZERO_G_COMPUTE_MODE=real
ZERO_G_COMPUTE_PROVIDER=
ZERO_G_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.2-3b-instruct:free

# 0G EVM RPC (used by Compute only — storage migrated to Crust below)
ZERO_G_EVM_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_PRIVATE_KEY=

# ── Storage — Crust Network (Polkadot parachain) ─────────────────
# "crust"  → publish agent manifests + knowledge files to IPFS via Crust Network
# "mock"   → local dev only (no on-chain proof; files saved to filesystem)
STORAGE_PROVIDER=mock
# Public Crust IPFS gateway (or use https://ipfs.io for read-only retrieval)
CRUST_GATEWAY=https://gw.crustfiles.app
# Crust seed phrase for signing storage orders (required when STORAGE_PROVIDER=crust)
CRUST_SEED=

# ── KILT Protocol — Proof of Personhood ─────────────────────────
# "mock"  → dev/demo; accepts any JSON with a `claim` field (no Spiritnet connection)
# "real"  → production; verifies credential via @kiltprotocol/sdk-js + Spiritnet
KILT_VERIFY_MODE=mock
KILT_WSS_ADDRESS=wss://spiritnet.kilt.io

# ── Polkadot / PAPI ─────────────────────────────────────────────
# People Chain RPC — on-chain identity queries (display name + registrar judgements)
POLKADOT_PEOPLE_RPC=wss://polkadot-people-rpc.polkadot.io
# Crust Network RPC — storage proof verification (api.query.market.filesV2)
CRUST_RPC=wss://rpc.crust.network

# ── Payments webhook ─────────────────────────────────────────────
# If set, /api/webhooks/payments requires matching x-webhook-secret header.
PAYMENTS_WEBHOOK_SECRET=
